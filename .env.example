# Google Gemini API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Lightweight/fast model. You can replace with a newer Gemini Flash model if available in your account.
GEMINI_MODEL=gemini-2.5-flash

# Optional external intelligence database.
# If empty, the project still works using public GeoIP/RDAP/RIPEstat/DNS data.
ABUSEIPDB_API_KEY=

# Network timeouts and safe defaults
REQUEST_TIMEOUT_SECONDS=8
PING_COUNT=4
PORT_TIMEOUT_SECONDS=1.2
MAX_PORTS_TO_CHECK=18
ENABLE_TRACEROUTE=false
